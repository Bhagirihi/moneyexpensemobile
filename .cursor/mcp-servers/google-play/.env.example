# Google account that owns the Play Console developer account
GOOGLE_ACCOUNT_EMAIL=my.website.email2@gmail.com

# Developer account display name
PLAY_DEVELOPER_NAME="Bhagihiri Applications"

# Play Console app display name
PLAY_APP_TITLE=Trivense

# Trivense Android package (must already exist in Play Console)
PLAY_PACKAGE_NAME=com.trivense.app

# Path to manifest (listing + subscriptions)
PLAY_MANIFEST_PATH=store-assets/play/manifest.json

# Regions version from https://play.google.com/supported-locations/ (dropdown)
PLAY_REGIONS_VERSION=2025/03

# Auth mode: service_account (recommended) or oauth
PLAY_AUTH_MODE=service_account

# Service account JSON filename inside credentials/
SERVICE_ACCOUNT_FILE=service_account.json
