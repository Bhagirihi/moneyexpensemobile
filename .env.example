EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# RevenueCat (App Store / Play Billing) — Trivense project (proj2d578859)
# Keys from RevenueCat dashboard → Apps → API keys (already provisioned)
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=appl_zAcnKrQHwmEZBckJSWcHFTTTywd
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=goog_yEuXEgHvGCpioYQwECAhRiQAhFM
# Test Store key for local dev builds when store apps are not configured yet
EXPO_PUBLIC_REVENUECAT_TEST_API_KEY=test_IGvFDXFXmmGKdvrwdPuGhNfuIIy

# RevenueCat API v2 (server/script only — for npm run setup:revenuecat or MCP alternative)
REVENUECAT_API_V2_KEY=sk_your_v2_secret_key
REVENUECAT_PROJECT_ID=proj2d578859

# Sentry crash reporting (optional but recommended for production)
# Create org "trivense" + project "trivense-mobile" at https://sentry.io
# Then: Settings → Projects → Client Keys (DSN) and Auth Tokens for releases
EXPO_PUBLIC_SENTRY_DSN=https://your_key@o000000.ingest.sentry.io/0000000
SENTRY_ORG=trivense
SENTRY_PROJECT=trivense-mobile

# Firebase (project: trivense-app-prod — configs in /firebase)
EXPO_PUBLIC_FIREBASE_PROJECT_ID=trivense-app-prod
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=265290976146

# AdMob (create at https://admob.google.com → link to Firebase trivense-app-prod)
# EXPO_PUBLIC_ADMOB_ANDROID_APP_ID=ca-app-pub-xxxxxxxx~xxxxxxxx
# EXPO_PUBLIC_ADMOB_IOS_APP_ID=ca-app-pub-xxxxxxxx~xxxxxxxx

# Optional — speeds up demo seeding (scripts/seed-demo-data.js)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Google Drive backup (create OAuth client IDs in Google Cloud Console, enable Drive API)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your_google_web_client_id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your_google_ios_client_id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your_google_android_client_id.apps.googleusercontent.com

# RevenueCat webhook edge function (set in Supabase project secrets via CLI, not in the mobile app)
# supabase secrets set REVENUECAT_WEBHOOK_AUTH=$(openssl rand -hex 32)
# Webhook URL: https://YOUR_PROJECT_REF.supabase.co/functions/v1/revenuecat-webhook
