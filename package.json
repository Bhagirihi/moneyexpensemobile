{
  "name": "Trivense",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "bash scripts/ensure-android-env.sh",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "seed:demo": "node scripts/seed-demo-data.js",
    "seed:demo:reset": "node scripts/seed-demo-data.js --reset",
    "setup:revenuecat": "node scripts/setup-revenuecat-trivense.js",
    "sync:revenuecat-pricing": "node scripts/sync-revenuecat-pricing.js",
    "generate:promo": ".venv/bin/python scripts/generate-promo-banners.py",
    "generate:assets": ".venv/bin/python scripts/refine-brand-assets.py",
    "generate:play-listing": ".venv/bin/python scripts/generate_play_listing_assets.py",
    "generate:store-listing": ".venv/bin/python scripts/generate_store_listing_system.py",
    "setup:status": "node scripts/print-setup-status.js",
    "setup:supabase": "node scripts/setup-supabase-trivense.js",
    "setup:google-auth": "node scripts/setup-google-auth-supabase.js",
    "setup:play": "bash scripts/setup-play-internal-testing.sh",
    "setup:play:open": "bash scripts/setup-play-open-testing.sh",
    "sync:eas-env": "node scripts/sync-eas-production-env.js",
    "build:android:local": "bash scripts/build-android-release-local.sh",
    "submit:open-testing": "bash scripts/submit-open-testing.sh",
    "qa:preflight": "node scripts/qa-preflight.js",
    "test": "jest",
    "test:ui": "jest tests/ui --runInBand",
    "test:e2e": "bash scripts/run-device-qa.sh smoke",
    "test:e2e:guest": "bash scripts/run-device-qa.sh guest",
    "test:e2e:auth": "bash scripts/run-device-qa.sh auth",
    "test:e2e:all": "bash scripts/run-device-qa.sh all",
    "test:e2e:stability": "bash scripts/run-maestro-stability.sh 3",
    "qa:device": "bash scripts/run-device-qa.sh all",
    "qa:stability": "bash scripts/run-maestro-stability.sh 3",
    "qa:full": "bash scripts/run-full-qa.sh 3",
    "qa:maestro-preflight": "bash scripts/qa-maestro-preflight.sh",
    "qa:ui": "node scripts/run-ui-qa.js",
    "qa:native-imports": "node scripts/qa-native-imports.js",
    "setup:admob": "node scripts/setup-admob-trivense.js && open 'https://admob.google.com/v2/apps/5149530682/adunits/list'",
    "setup:admob-mcp": "bash scripts/setup-admob-mcp.sh",
    "setup:sentry": "node scripts/setup-sentry-trivense.js",
    "apply:admob-production": "node scripts/apply-admob-production.js",
    "create:admob-units": "bash scripts/create-admob-units-trivense.sh",
    "admob:check": "node scripts/apply-admob-env.js",
    "push:github": "git push https://x-access-token:$(gh auth token)@github.com/Bhagirihi/moneyexpensemobile.git HEAD:main"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.3.0",
    "@expo-google-fonts/manrope": "^0.3.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-clipboard/clipboard": "^1.16.3",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-navigation/native": "^7.1.6",
    "@react-navigation/native-stack": "^7.3.1",
    "@react-navigation/stack": "^7.2.1",
    "@sentry/react-native": "~7.2.0",
    "@supabase/supabase-js": "^2.50.0",
    "dotenv": "^16.5.0",
    "expo": "~54.0.35",
    "expo-asset": "~12.0.13",
    "expo-auth-session": "~7.0.11",
    "expo-build-properties": "~1.0.10",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.9",
    "expo-device": "~8.0.10",
    "expo-file-system": "~19.0.23",
    "expo-font": "~14.0.12",
    "expo-image-picker": "~17.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-location": "~19.0.8",
    "expo-notifications": "~0.32.17",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.11",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-get-random-values": "^1.11.0",
    "react-native-google-mobile-ads": "^16.3.4",
    "react-native-purchases": "^10.4.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-toast-message": "^2.3.0",
    "react-native-ui-datepicker": "^3.1.2",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/react": "~19.1.10",
    "babel-preset-expo": "~54.0.0",
    "expo-dev-client": "~6.0.21",
    "expo-env": "^1.1.1",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.0",
    "react-test-renderer": "^19.1.0",
    "supabase": "^2.107.0",
    "typescript": "~5.9.2"
  },
  "private": true,
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "listUnknownPackages": false
      }
    }
  }
}
